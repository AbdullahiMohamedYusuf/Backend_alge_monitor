{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "GD32V Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/gd32vf103_debug.elf",
      "svdfile": "GD32VF103.svd",
      "args": [
        "--target=riscv32-unknown-elf"
      ],
      "cwd": "${workspaceFolder}",
      "miDebuggerServerAddress": "COM5",
      "MIMode": "gdb",
      "miDebuggerPath": "${workspaceFolder}/../../compiler/bin/riscv64-unknown-elf-gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "text": "set architecture riscv:rv32"
        },
        {
          "text": "set remotelogfile debug_log.txt"
        },
        {
          "text": "set remotebreak on"
        }
      ]
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "c:/Users/abdul/OneDrive/Documents/toolchain-gd32v-v202-win/projects/nArbete",
      "program": "c:/Users/abdul/OneDrive/Documents/toolchain-gd32v-v202-win/projects/nArbete/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "${workspaceFolder}/../../compiler/bin/riscv64-unknown-elf-gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}